# ==============================================
# IrisFlow — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# ==============================================

# --- Ambiente ---
ENVIRONMENT=development   # development | production

# --- Banco de dados ---
# Dev: SQLite (não precisa alterar)
DATABASE_URL=sqlite:///./irisflow.db
# Prod: descomentar e preencher com URL do Supabase
# DATABASE_URL=postgresql://user:password@host:5432/irisflow

# --- Supabase (auth + banco em produção) ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-publica
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# --- JWT (autenticação local) ---
SECRET_KEY=gere-uma-chave-aleatoria-forte-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Stripe (pagamentos) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_FAMILIAR=price_...
STRIPE_PRICE_ID_CLINICA=price_...
STRIPE_PRICE_ID_HOSPITALAR=price_...

# --- Engine de IA ---
# Câmera: índice da câmera (0 = padrão do sistema)
CAMERA_INDEX=0
# Modelo Whisper: tiny | base | small | medium | large
WHISPER_MODEL=small
# TTS: coqui | pyttsx3
TTS_ENGINE=coqui

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Redis (opcional, Mês 4+) ---
# REDIS_URL=redis://localhost:6379
